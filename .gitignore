# Credentials & secrets
.credentials.json
mcp-needs-auth-cache.json

# Python cache
__pycache__/
*.pyc

# Vector DB (local, regenerated by indexer)
memory/_vectordb/

# Workflow session states (ephemeral)
workflow/state-*.json

# Cache & generated
cache/
debug/
file-history/
downloads/
shell-snapshots/
telemetry/
todos/
backups/
plans/
ide/
plugins/
stats-cache.json

# Session transcripts (huge, not needed in repo)
projects/*/*.jsonl
projects/*/*/

# Keep only memory/ directories inside projects
!projects/*/memory/
!projects/*/memory/**
