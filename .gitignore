# Credentials & secrets
.credentials.json
mcp-needs-auth-cache.json

# Python cache
__pycache__/
*.pyc

# Vector DB (local, regenerated by indexer)
memory/_vectordb/

# Episodic atoms (TTL 24d, auto-generated, not for version control)
memory/episodic/

# Distant memory archive (expired atoms)
memory/_distant/

# User-specific atoms (hardware, local env, not for shared repo)
memory/hardware.md

# Workflow session states (ephemeral)
workflow/state-*.json

# Nested .claude (auto-generated by Claude Code)
.claude/

# Session environment snapshots (ephemeral)
session-env/

# Cache & generated
cache/
debug/
file-history/
downloads/
shell-snapshots/
telemetry/
todos/
backups/
plans/
ide/
plugins/
stats-cache.json

# Session transcripts (huge, not needed in repo)
projects/*/*.jsonl
projects/*/*/

# Only keep OpenClaw project memory in git
!projects/e--OpenClawWorkSpace/memory/
!projects/e--OpenClawWorkSpace/memory/**
